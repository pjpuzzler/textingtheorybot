{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "textingtheorybot",
  "permissions": {
    "media": true,
    "reddit": {
      "enable": true,
      "asUser": ["SUBMIT_POST", "SUBMIT_COMMENT"]
    }
  },
  "menu": {
    "items": [
      {
        "label": "Apply Post Elo Flair",
        "forUserType": "moderator",
        "location": "post",
        "endpoint": "/internal/menu/mod-apply-post-elo-flair"
      },
      {
        "label": "Reply With Classification Image",
        "forUserType": "moderator",
        "location": "comment",
        "endpoint": "/internal/menu/comment-reply-classification",
        "postFilter": "none"
      }
    ]
  },
  "forms": {
    "commentReplyClassification": "/internal/forms/comment-reply-classification"
  },
  "post": {
    "dir": "public",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "post.html"
      },
      "expanded": {
        "entry": "post-expanded.html"
      },
      "create": {
        "entry": "app.html"
      },
      "edit": {
        "entry": "app-edit.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.js"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "dev": "node --experimental-strip-types ./tools/build.ts --watch",
    "build": "node --experimental-strip-types ./tools/build.ts --minify"
  },
  "marketingAssets": {
    "icon": "public/assets/logo.png"
  }
}
